# Ksher AgentAI 智能工作台 — 环境变量配置
# 复制本文件为 .env，然后填入你的真实 API Key
# ⚠️ .env 文件不会被提交到 Git（已在 .gitignore 中排除）

# ==========================================
# Claude API（精准型Agent：成本/方案/知识问答）
# 获取地址：https://console.anthropic.com
# 模型：claude-sonnet-4-6-20250514
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# Kimi API（创意型Agent：话术/内容/设计/异议）
# 获取地址：https://platform.moonshot.cn
# 模型：kimi-k2.5
# ==========================================
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# 模型配置（一般不需要修改）
# ==========================================
MODEL_NAME_SONNET=claude-sonnet-4-6-20250514
MODEL_NAME_KIMI=kimi-k2.5

# ==========================================
# Streamlit UI 配置
# ==========================================
STREAMLIT_THEME=dark

# ==========================================
# 项目配置
# ==========================================
KNOWLEDGE_DIR=knowledge/
DATA_DIR=data/
ASSETS_DIR=assets/
